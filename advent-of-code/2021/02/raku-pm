#!/usr/bin/env raku
# https://github.com/ryanwinchester/advent-of-code-elixir/blob/master/lib/advent_2021/day_02.ex
my @a = $*ARGFILES.lines;

multi travel(@a) { samewith(@a, BagHash.new); }
multi travel([$ where rx:s/down    (.*)/, *@a], $bh) { $bh (+)= :y1($0); samewith(@a, $bh); }
multi travel([$ where rx:s/up      (.*)/, *@a], $bh) { $bh (-)= :y1($0); samewith(@a, $bh); }
multi travel([$ where rx:s/forward (.*)/, *@a], $bh) { $bh (+)= (:x($0),:y2($0*$bh<y1>); samewith(@a, $bh); }
multi travel([], $bh) { $bh; }

say travel(@a);
